              <View style={{ gap: 12 }}>
                {insights.map((insight, idx) => (
                  <SectionCard
                    key={idx}
                    style={{
                      borderWidth: 1,
                      borderColor: theme.colors.outlineVariant,
                      backgroundColor: theme.colors.elevation.level1,
                      padding: 14,
