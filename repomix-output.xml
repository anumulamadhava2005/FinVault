                placeholder="Search transactions…"
                value={searchQuery}
                onChangeText={setSearchQuery}
                style={{
                  flex: 1,
                  elevation: 0,
                  borderWidth: 1,
                  borderColor: theme.colors.outlineVariant,
                  backgroundColor: theme.colors.surface,
                  height: 44,
