              dense
              style={{ marginBottom: 8 }}
              placeholder="e.g. 98.5"
            />
            <TextInput
              label="Tax Benefit Section"
              value={form.tax_benefit}
              onChangeText={(v) => set('tax_benefit', v)}
              mode="outlined"
              dense
              style={{ marginBottom: 8 }}
