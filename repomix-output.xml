remaining = max(goal.target - goal.current, 0)
focusMonths = ceil(remaining / goal.monthly_needed) if goal.monthly_needed > 0 else 0
projection = pct >= 100 ? 'Achieved 🎉' : focusMonths > 0 ? `~${focusMonths} mo` : 'Set monthly'
