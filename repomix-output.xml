                              textColor={palette.danger}
                              onPress={() => setConfirmId(e.id)}
                              style={{ borderRadius: theme.roundness, borderColor: palette.danger }}
                              labelStyle={{ fontSize: 11 }}
                            >
                              Delete
                            </Button>
                          </View>
                        </View>
                      )}
                    </SectionCard>
                  );
                })}
              </View>
            )}
          </View>
