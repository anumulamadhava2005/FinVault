              borderColor: theme.colors.errorContainer,
              borderWidth: 1,
              backgroundColor: theme.colors.errorContainer + '11',
              borderRadius: theme.roundness,
              elevation: 0,
              overflow: 'hidden',
              marginTop: 4,
            }}
