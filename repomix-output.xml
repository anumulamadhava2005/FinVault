  content: { flex: 1, paddingLeft: 10, paddingBottom: 16 },
  contentRow: { flexDirection: 'row', alignItems: 'center', gap: 8 },
  name: { flex: 1, fontWeight: '700' },
});

export default GoalTimeline;
</file>

