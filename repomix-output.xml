                  />
                )}
              </>
            )}
          </Dialog.Content>
          {!isGenerating && (
            <Dialog.Actions>
              <Button onPress={() => setPdfDialogOpen(false)}>Cancel</Button>
              <Button 
                mode="contained" 
                disabled={!pdfPassword.trim()} 
                onPress={onExportPdf}
              >
                Generate PDF
              </Button>
            </Dialog.Actions>
          )}
        </Dialog>
      </Portal>

      <Snackbar visible={!!snack} onDismiss={() => setSnack('')} duration={2500}>
        {snack}
      </Snackbar>
    </>
  );
};

export default ReportsScreen;
