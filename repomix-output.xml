                    <View style={{ flexDirection: 'row', alignItems: 'flex-start', gap: 12 }}>
                      <View style={{
                        backgroundColor: insight.includes('increased') || insight.includes('▲') ? 'rgba(235, 94, 85, 0.12)' : 'rgba(82, 167, 126, 0.12)',
