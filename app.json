{
  "expo": {
    "name": "FinVault",
    "slug": "FinVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "finvault",
    "userInterfaceStyle": "automatic",
    "privacy": "public",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.finvault.app",
      "supportsTablet": false,
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#181818"
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "FinVault uses Face ID to securely unlock your financial data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#181818",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.finvault.app",
      "softwareKeyboardLayoutMode": "pan",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#181818",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "FinVault needs access to your photos to attach images to assets.",
          "cameraPermission": "FinVault needs camera access to photograph asset documents."
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
